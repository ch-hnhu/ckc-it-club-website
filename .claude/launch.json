{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "user-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend/user"],
      "port": 5175,
      "autoPort": false
    },
    {
      "name": "admin-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend/admin"],
      "port": 5173,
      "autoPort": false
    },
    {
      "name": "admin-frontend-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend/admin", "--", "--port", "5180", "--strictPort"],
      "port": 5180,
      "autoPort": false
    },
    {
      "name": "user-frontend-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend/user", "--", "--port", "5181", "--strictPort"],
      "port": 5181,
      "autoPort": false
    },
    {
      "name": "backend",
      "runtimeExecutable": "php",
      "runtimeArgs": ["backend/artisan", "serve", "--host", "127.0.0.1", "--port", "8000"],
      "port": 8000,
      "autoPort": false
    }
  ]
}
